# Required on Vercel. Install a Redis provider from the Vercel Marketplace and
# use the connection URL it provides. Local development falls back to memory.
REDIS_URL="redis://default:password@host:6379"

# Public production origin used by Socket.IO CORS checks for a custom domain.
# Vercel preview and production *.vercel.app URLs are detected automatically.
APP_URL="https://your-harmony-domain.example"
